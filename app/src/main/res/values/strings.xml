    <!-- OriginOS Survival -->
    <string name="originos_survival_title">OriginOS Survival (CRITICAL)</string>
    <string name="originos_survival_desc">Your phone will kill LaT OS unless you do ALL of these:</string>
    <string name="originos_step_1">1. Settings → Battery → Background power consumption → Allow LaT OS</string>
    <string name="originos_step_2">2. Settings → Apps → Permissions → Autostart → Enable LaT OS</string>
    <string name="originos_step_3">3. Settings → Apps → LaT OS → Battery → Remove background restriction</string>
    <string name="originos_step_4">4. Recent Apps → Long press LaT OS card → Lock</string>
    <string name="originos_step_5">5. Settings → Battery → High background power consumption → Allow</string>

